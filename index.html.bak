<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WMS 仓库管理系统</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--primary:#4f46e5;--primary-light:#818cf8;--primary-dark:#3730a3;--success:#10b981;--warning:#f59e0b;--danger:#ef4444;--info:#3b82f6;--gray-50:#f9fafb;--gray-100:#f3f4f6;--gray-200:#e5e7eb;--gray-300:#d1d5db;--gray-400:#9ca3af;--gray-500:#6b7280;--gray-600:#4b5563;--gray-700:#374151;--gray-800:#1f2937;--gray-900:#111827;--shadow:0 1px 3px rgba(0,0,0,.1);--shadow-lg:0 10px 15px -3px rgba(0,0,0,.1);--radius:8px;--radius-lg:12px}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--gray-50);color:var(--gray-800);line-height:1.5}
.header{background:linear-gradient(135deg,var(--primary-dark),var(--primary),var(--primary-light));color:#fff;padding:16px 24px;display:flex;align-items:center;justify-content:space-between;box-shadow:var(--shadow-lg);position:sticky;top:0;z-index:100}
.header h1{font-size:20px;font-weight:700;display:flex;align-items:center;gap:8px}
.header-right{display:flex;align-items:center;gap:12px;font-size:13px;opacity:.9}
.tab-bar{background:#fff;border-bottom:1px solid var(--gray-200);display:flex;overflow-x:auto;position:sticky;top:56px;z-index:99}
.tab-btn{padding:12px 20px;border:none;background:none;font-size:14px;font-weight:500;color:var(--gray-500);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s}
.tab-btn:hover{color:var(--primary);background:var(--gray-50)}
.tab-btn.active{color:var(--primary);border-bottom-color:var(--primary);font-weight:600}
.container{max-width:1400px;margin:0 auto;padding:20px}
.tab-content{display:none}.tab-content.active{display:block}
.card{background:#fff;border-radius:var(--radius-lg);box-shadow:var(--shadow);overflow:hidden;margin-bottom:16px}
.card-header{padding:16px 20px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;justify-content:space-between}
.card-header h2{font-size:16px;font-weight:600}
.card-body{padding:20px}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:20px}
.stat-card{background:#fff;border-radius:var(--radius-lg);padding:20px;box-shadow:var(--shadow);border-left:4px solid var(--primary)}
.stat-card.green{border-left-color:var(--success)}.stat-card.orange{border-left-color:var(--warning)}.stat-card.blue{border-left-color:var(--info)}.stat-card.red{border-left-color:var(--danger)}
.stat-label{font-size:12px;color:var(--gray-500);text-transform:uppercase;letter-spacing:.5px}
.stat-value{font-size:28px;font-weight:700;color:var(--gray-900);margin-top:4px}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border:none;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;transition:all .15s}
.btn-primary{background:var(--primary);color:#fff}.btn-primary:hover{background:var(--primary-dark)}
.btn-success{background:var(--success);color:#fff}
.btn-danger{background:var(--danger);color:#fff}
.btn-warning{background:var(--warning);color:#fff}
.btn-info{background:var(--info);color:#fff}
.btn-outline{background:#fff;color:var(--gray-700);border:1px solid var(--gray-300)}
.btn-sm{padding:5px 10px;font-size:12px}
.btn-group{display:flex;gap:6px;flex-wrap:wrap}
.form-group{margin-bottom:14px}
.form-label{display:block;font-size:13px;font-weight:500;color:var(--gray-700);margin-bottom:4px}
.form-control{width:100%;padding:8px 12px;border:1px solid var(--gray-300);border-radius:6px;font-size:13px}
.form-control:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px rgba(79,70,229,.1)}
.form-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px}
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:var(--gray-50);padding:10px 12px;text-align:left;font-weight:600;color:var(--gray-600);border-bottom:2px solid var(--gray-200);white-space:nowrap}
td{padding:10px 12px;border-bottom:1px solid var(--gray-100)}
tr:hover{background:var(--gray-50)}
.table-empty{text-align:center;padding:40px;color:var(--gray-400)}
.badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600}
.badge-success{background:#d1fae5;color:#065f46}
.badge-warning{background:#fef3c7;color:#92400e}
.badge-danger{background:#fee2e2;color:#991b1b}
.badge-info{background:#dbeafe;color:#1e40af}
.badge-gray{background:var(--gray-100);color:var(--gray-600)}
.toolbar{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center}
.search-input{padding:8px 12px;border:1px solid var(--gray-300);border-radius:6px;font-size:13px;width:250px}
.search-input:focus{outline:none;border-color:var(--primary)}
.filter-select{padding:8px 12px;border:1px solid var(--gray-300);border-radius:6px;font-size:13px;background:#fff}
.pagination{display:flex;align-items:center;justify-content:center;gap:4px;margin-top:16px}
.page-btn{padding:6px 10px;border:1px solid var(--gray-300);border-radius:4px;background:#fff;font-size:12px;cursor:pointer}
.page-btn.active{background:var(--primary);color:#fff;border-color:var(--primary)}
.page-btn:disabled{opacity:.4;cursor:not-allowed}
.page-info{font-size:12px;color:var(--gray-500);margin:0 8px}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:200;opacity:0;pointer-events:none;transition:opacity .2s}
.modal-overlay.show{opacity:1;pointer-events:all}
.modal{background:#fff;border-radius:var(--radius-lg);width:90%;max-width:600px;max-height:85vh;overflow:auto;box-shadow:var(--shadow-lg);transform:scale(.95);transition:transform .2s}
.modal-overlay.show .modal{transform:scale(1)}
.modal-header{padding:16px 20px;border-bottom:1px solid var(--gray-200);display:flex;align-items:center;justify-content:space-between}
.modal-header h3{font-size:16px;font-weight:600}
.modal-close{width:28px;height:28px;border:none;background:var(--gray-100);border-radius:50%;cursor:pointer;font-size:16px}
.modal-body{padding:20px}
.modal-footer{padding:12px 20px;border-top:1px solid var(--gray-200);display:flex;justify-content:flex-end;gap:8px}
.autocomplete-wrap{position:relative}
.autocomplete-list{position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid var(--gray-300);border-top:none;border-radius:0 0 6px 6px;max-height:200px;overflow:auto;z-index:50;display:none;box-shadow:var(--shadow)}
.autocomplete-list.show{display:block}
.autocomplete-item{padding:8px 12px;cursor:pointer;font-size:13px;display:flex;justify-content:space-between}
.autocomplete-item:hover{background:var(--gray-50)}
.autocomplete-item .code{font-weight:600;color:var(--primary)}
.toast-container{position:fixed;top:70px;right:20px;z-index:300;display:flex;flex-direction:column;gap:8px}
.toast{padding:12px 16px;border-radius:8px;color:#fff;font-size:13px;font-weight:500;box-shadow:var(--shadow-lg);animation:slideIn .3s;min-width:250px;display:flex;align-items:center;gap:8px}
.toast.success{background:var(--success)}.toast.error{background:var(--danger)}.toast.info{background:var(--info)}
@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
.sub-tabs{display:flex;gap:0;border-bottom:2px solid var(--gray-200);margin-bottom:16px}
.sub-tab{padding:10px 18px;font-size:13px;font-weight:500;color:var(--gray-500);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px}
.sub-tab:hover{color:var(--primary)}.sub-tab.active{color:var(--primary);border-bottom-color:var(--primary)}
.sub-content{display:none}.sub-content.active{display:block}
.chart-bar-wrap{margin-top:12px}
.chart-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.chart-bar-label{width:100px;font-size:12px;color:var(--gray-600);text-align:right;flex-shrink:0}
.chart-bar-track{flex:1;height:24px;background:var(--gray-100);border-radius:4px;overflow:hidden}
.chart-bar{height:100%;border-radius:4px;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;font-size:11px;color:#fff;font-weight:600;min-width:30px}
.chart-bar-qty{font-size:12px;color:var(--gray-500);width:60px;text-align:right;flex-shrink:0}
@media(max-width:768px){.header{padding:12px 16px}.header h1{font-size:16px}.container{padding:12px}.toolbar{flex-direction:column}.search-input{width:100%}.stats-grid{grid-template-columns:1fr 1fr}.form-row{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="header"><h1><span>📦</span> WMS 仓库管理系统</h1><div class="header-right"><span id="connStatus">⏳ 连接中...</span><span>WMS v1.0</span></div></div>
<div class="tab-bar">
<button class="tab-btn active" data-tab="inbound">📥 入库管理</button>
<button class="tab-btn" data-tab="stock">📊 库存管理</button>
<button class="tab-btn" data-tab="request">📋 申领管理</button>
<button class="tab-btn" data-tab="outbound">📤 出库管理</button>
<button class="tab-btn" data-tab="dashboard">📈 数据总览</button>
<button class="tab-btn" data-tab="master">⚙️ 主数据管理</button>
</div>
<div class="toast-container" id="toastContainer"></div>
<div class="container">
<div class="tab-content active" id="tab-inbound"><div class="card"><div class="card-header"><h2>📥 入库管理</h2><button class="btn btn-primary" onclick="showModal('inboundModal')">+ 新建入库单</button></div><div class="card-body"><div class="toolbar"><input type="text" class="search-input" placeholder="🔍 搜索..." id="inboundSearch" oninput="loadInbound()"><select class="filter-select" id="inboundStatusFilter" onchange="loadInbound()"><option value="">全部状态</option><option value="Planned">Planned</option><option value="Completed">Completed</option></select></div><div class="table-wrap"><table><thead><tr><th>入库单号</th><th>类型</th><th>物料编码</th><th>名称</th><th>计划数量</th><th>实际数量</th><th>状态</th><th>供应商</th><th>区域</th><th>操作</th></tr></thead><tbody id="inboundTable"></tbody></table></div><div id="inboundPagination" class="pagination"></div></div></div></div>
<div class="tab-content" id="tab-stock"><div class="stats-grid"><div class="stat-card"><div class="stat-label">总物料数</div><div class="stat-value" id="stat-materials">-</div></div><div class="stat-card green"><div class="stat-label">总库存量</div><div class="stat-value" id="stat-stock">-</div></div><div class="stat-card blue"><div class="stat-label">可用库存</div><div class="stat-value" id="stat-available">-</div></div></div><div class="card"><div class="card-header"><h2>📊 库存明细</h2><button class="btn btn-warning btn-sm" onclick="showModal('scrapModal')">🗑️ 库存报废</button></div><div class="card-body"><div class="toolbar"><input type="text" class="search-input" placeholder="🔍 搜索..." id="stockSearch" oninput="loadStock()"></div><div class="table-wrap"><table><thead><tr><th>物料编码</th><th>名称</th><th>库存</th><th>可用</th><th>计划分配</th><th>待维修</th><th>部门</th></tr></thead><tbody id="stockTable"></tbody></table></div></div></div></div>
<div class="tab-content" id="tab-request"><div class="card"><div class="card-header"><h2>📋 申领管理</h2><button class="btn btn-primary" onclick="showModal('requestModal')">+ 新建申领</button></div><div class="card-body"><div class="toolbar"><input type="text" class="search-input" placeholder="🔍 搜索..." id="requestSearch" oninput="loadRequests()"><select class="filter-select" id="requestStatusFilter" onchange="loadRequests()"><option value="">全部状态</option><option value="Pending">Pending</option><option value="Approved">Approved</option><option value="Rejected">Rejected</option></select></div><div class="table-wrap"><table><thead><tr><th>单号</th><th>物料编码</th><th>名称</th><th>申领量</th><th>审批量</th><th>状态</th><th>区域</th><th>配送</th><th>操作</th></tr></thead><tbody id="requestTable"></tbody></table></div><div id="requestPagination" class="pagination"></div></div></div></div>
<div class="tab-content" id="tab-outbound"><div class="card"><div class="card-header"><h2>📤 出库管理</h2><button class="btn btn-primary" onclick="showModal('outboundBatchModal')">+ 创建批次</button></div><div class="card-body"><div class="toolbar"><input type="text" class="search-input" placeholder="🔍 搜索批次..." id="outboundSearch" oninput="loadOutbound()"></div><h3 style="margin-bottom:12px;font-size:14px">出库批次</h3><div class="table-wrap"><table><thead><tr><th>批次号</th><th>状态</th><th>请求数</th><th>操作</th></tr></thead><tbody id="batchTable"></tbody></table></div><h3 style="margin:20px 0 12px;font-size:14px">出库明细</h3><div class="table-wrap"><table><thead><tr><th>单号</th><th>物料编码</th><th>名称</th><th>状态</th><th>出库量</th><th>收货量</th><th>操作</th></tr></thead><tbody id="outboundRecordTable"></tbody></table></div></div></div></div>
<div class="tab-content" id="tab-dashboard"><div class="stats-grid"><div class="stat-card"><div class="stat-label">物料种类</div><div class="stat-value" id="dash-materials">-</div></div><div class="stat-card green"><div class="stat-label">总库存</div><div class="stat-value" id="dash-stock">-</div></div><div class="stat-card blue"><div class="stat-label">可用库存</div><div class="stat-value" id="dash-available">-</div></div><div class="stat-card orange"><div class="stat-label">待处理</div><div class="stat-value" id="dash-pending">-</div></div><div class="stat-card"><div class="stat-label">入库单</div><div class="stat-value" id="dash-inbound">-</div></div><div class="stat-card red"><div class="stat-label">报废</div><div class="stat-value" id="dash-scrap">-</div></div></div><div class="card"><div class="card-header"><h2>📊 库存按部门分布</h2></div><div class="card-body"><div class="chart-bar-wrap" id="deptChart"></div></div></div></div>
<div class="tab-content" id="tab-master"><div class="sub-tabs"><div class="sub-tab active" data-sub="material">📦 物料</div><div class="sub-tab" data-sub="store">🏪 门店</div><div class="sub-tab" data-sub="contact">👤 联系人</div><div class="sub-tab" data-sub="receiver">📮 收货方</div><div class="sub-tab" data-sub="region">🌍 区域</div></div>
<div class="sub-content active" id="sub-material"><div class="card"><div class="card-header"><h2>📦 物料主数据</h2><button class="btn btn-primary btn-sm" onclick="openModal('materialModal')">+ 新增</button></div><div class="card-body"><div class="toolbar"><input type="text" class="search-input" placeholder="🔍 搜索..." id="materialSearch" oninput="loadMasterData()"><select class="filter-select" id="materialDeptFilter" onchange="loadMasterData()"><option value="">全部部门</option></select></div><div class="table-wrap"><table><thead><tr><th>编码</th><th>名称</th><th>部门</th><th>单位</th><th>规格</th><th>状态</th><th>操作</th></tr></thead><tbody id="materialTable"></tbody></table></div></div></div></div>
<div class="sub-content" id="sub-store"><div class="card"><div class="card-header"><h2>🏪 门店主数据</h2><button class="btn btn-primary btn-sm" onclick="openModal('storeModal')">+ 新增</button></div><div class="card-body"><div class="toolbar"><input type="text" class="search-input" placeholder="🔍 搜索..." id="storeSearch" oninput="loadMasterData()"><select class="filter-select" id="storeRegionFilter" onchange="loadMasterData()"><option value="">全部区域</option></select><select class="filter-select" id="storeStatusFilter" onchange="loadMasterData()"><option value="">全部状态</option><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div><div class="table-wrap"><table><thead><tr><th>编码</th><th>名称</th><th>区域</th><th>渠道</th><th>省份</th><th>商场</th><th>状态</th><th>操作</th></tr></thead><tbody id="storeTable"></tbody></table></div></div></div></div>
<div class="sub-content" id="sub-contact"><div class="card"><div class="card-header"><h2>👤 联系人</h2><button class="btn btn-primary btn-sm" onclick="openModal('contactModal')">+ 新增</button></div><div class="card-body"><div class="toolbar"><input type="text" class="search-input" placeholder="🔍 搜索..." id="contactSearch" oninput="loadMasterData()"></div><div class="table-wrap"><table><thead><tr><th>姓名</th><th>部门</th><th>区域-部门</th><th>电话</th><th>邮箱</th><th>操作</th></tr></thead><tbody id="contactTable"></tbody></table></div></div></div></div>
<div class="sub-content" id="sub-receiver"><div class="card"><div class="card-header"><h2>📮 收货方</h2><button class="btn btn-primary btn-sm" onclick="openModal('receiverModal')">+ 新增</button></div><div class="card-body"><div class="toolbar"><input type="text" class="search-input" placeholder="🔍 搜索..." id="receiverSearch" oninput="loadMasterData()"></div><div class="table-wrap"><table><thead><tr><th>姓名</th><th>MI ID</th><th>电话</th><th>区域</th><th>部门</th><th>操作</th></tr></thead><tbody id="receiverTable"></tbody></table></div></div></div></div>
<div class="sub-content" id="sub-region"><div class="card"><div class="card-header"><h2>🌍 区域配置</h2><button class="btn btn-primary btn-sm" onclick="openModal('regionModal')">+ 新增</button></div><div class="card-body"><div class="table-wrap"><table><thead><tr><th>名称</th><th>状态</th><th>操作</th></tr></thead><tbody id="regionTable"></tbody></table></div></div></div></div>
</div></div>

<!-- MODALS -->
<div class="modal-overlay" id="inboundModal"><div class="modal"><div class="modal-header"><h3>创建入库单</h3><button class="modal-close" onclick="hideModal('inboundModal')">×</button></div><div class="modal-body"><div class="form-row"><div class="form-group"><label class="form-label">入库类型</label><select class="form-control" id="ib-type"><option value="Purchase">采购入库</option><option value="Return">退货入库</option><option value="Transfer">调拨入库</option></select></div><div class="form-group"><label class="form-label">部门</label><select class="form-control" id="ib-dept"><option value="Phone">Phone</option><option value="Pad">Pad</option><option value="AIOT">AIOT</option><option value="Wearables">Wearables</option></select></div></div><div class="form-group"><label class="form-label">物料</label><div class="autocomplete-wrap"><input type="text" class="form-control" id="ib-material-input" placeholder="输入编码或名称搜索..." oninput="onMatSearch(this,'ib-material-list','ib-material-code','ib-material-name')" onfocus="onMatSearch(this,'ib-material-list','ib-material-code','ib-material-name')"><input type="hidden" id="ib-material-code"><input type="hidden" id="ib-material-name"><div class="autocomplete-list" id="ib-material-list"></div></div></div><div class="form-row"><div class="form-group"><label class="form-label">计划数量</label><input type="number" class="form-control" id="ib-qty" min="1" value="1"></div><div class="form-group"><label class="form-label">供应商</label><input type="text" class="form-control" id="ib-supplier"></div></div><div class="form-row"><div class="form-group"><label class="form-label">区域</label><select class="form-control" id="ib-region"></select></div><div class="form-group"><label class="form-label">计划日期</label><input type="date" class="form-control" id="ib-date"></div></div></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('inboundModal')">取消</button><button class="btn btn-primary" onclick="createInbound()">创建</button></div></div></div>
<div class="modal-overlay" id="confirmInboundModal"><div class="modal" style="max-width:400px"><div class="modal-header"><h3>确认入库</h3><button class="modal-close" onclick="hideModal('confirmInboundModal')">×</button></div><div class="modal-body"><div class="form-group"><label class="form-label">实际入库数量</label><input type="number" class="form-control" id="confirm-qty" min="0"></div><input type="hidden" id="confirm-inbound-id"></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('confirmInboundModal')">取消</button><button class="btn btn-success" onclick="confirmInbound()">确认</button></div></div></div>
<div class="modal-overlay" id="requestModal"><div class="modal"><div class="modal-header"><h3>创建申领</h3><button class="modal-close" onclick="hideModal('requestModal')">×</button></div><div class="modal-body"><div class="form-group"><label class="form-label">物料</label><div class="autocomplete-wrap"><input type="text" class="form-control" id="req-material-input" placeholder="搜索物料..." oninput="onMatSearch(this,'req-material-list','req-material-code','req-material-name')" onfocus="onMatSearch(this,'req-material-list','req-material-code','req-material-name')"><input type="hidden" id="req-material-code"><input type="hidden" id="req-material-name"><div class="autocomplete-list" id="req-material-list"></div></div></div><div class="form-row"><div class="form-group"><label class="form-label">数量</label><input type="number" class="form-control" id="req-qty" min="1" value="1"></div><div class="form-group"><label class="form-label">区域</label><select class="form-control" id="req-region"></select></div></div><div class="form-row"><div class="form-group"><label class="form-label">配送方式</label><select class="form-control" id="req-deliver"><option value="Express">快递</option><option value="Self">自提</option><option value="Transfer">调拨</option></select></div><div class="form-group"><label class="form-label">收货人</label><select class="form-control" id="req-receiver"></select></div></div></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('requestModal')">取消</button><button class="btn btn-primary" onclick="createRequest()">创建</button></div></div></div>
<div class="modal-overlay" id="approveModal"><div class="modal" style="max-width:400px"><div class="modal-header"><h3>审批</h3><button class="modal-close" onclick="hideModal('approveModal')">×</button></div><div class="modal-body"><div class="form-group"><label class="form-label">审批数量</label><input type="number" class="form-control" id="approve-qty" min="0"></div><input type="hidden" id="approve-request-id"></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('approveModal')">取消</button><button class="btn btn-danger" onclick="rejectRequest()">驳回</button><button class="btn btn-success" onclick="approveRequest()">通过</button></div></div></div>
<div class="modal-overlay" id="outboundBatchModal"><div class="modal" style="max-width:400px"><div class="modal-header"><h3>创建出库批次</h3><button class="modal-close" onclick="hideModal('outboundBatchModal')">×</button></div><div class="modal-body"><div class="form-group"><label class="form-label">包含请求数</label><input type="number" class="form-control" id="batch-req-count" min="0" value="0"></div></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('outboundBatchModal')">取消</button><button class="btn btn-primary" onclick="createOutboundBatch()">创建</button></div></div></div>
<div class="modal-overlay" id="scrapModal"><div class="modal" style="max-width:450px"><div class="modal-header"><h3>库存报废</h3><button class="modal-close" onclick="hideModal('scrapModal')">×</button></div><div class="modal-body"><div class="form-group"><label class="form-label">物料</label><div class="autocomplete-wrap"><input type="text" class="form-control" id="scrap-material-input" placeholder="搜索..." oninput="onMatSearch(this,'scrap-material-list','scrap-material-code',null)" onfocus="onMatSearch(this,'scrap-material-list','scrap-material-code',null)"><input type="hidden" id="scrap-material-code"><div class="autocomplete-list" id="scrap-material-list"></div></div></div><div class="form-group"><label class="form-label">数量</label><input type="number" class="form-control" id="scrap-qty" min="1" value="1"></div><div class="form-group"><label class="form-label">原因</label><input type="text" class="form-control" id="scrap-reason"></div></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('scrapModal')">取消</button><button class="btn btn-danger" onclick="scrapStock()">确认报废</button></div></div></div>
<div class="modal-overlay" id="materialModal"><div class="modal"><div class="modal-header"><h3 id="materialModalTitle">新增物料</h3><button class="modal-close" onclick="hideModal('materialModal')">×</button></div><div class="modal-body"><input type="hidden" id="mat-edit-id"><div class="form-row"><div class="form-group"><label class="form-label">编码</label><input type="text" class="form-control" id="mat-code"></div><div class="form-group"><label class="form-label">名称</label><input type="text" class="form-control" id="mat-name"></div></div><div class="form-row"><div class="form-group"><label class="form-label">部门</label><select class="form-control" id="mat-dept"><option value="Phone">Phone</option><option value="Pad">Pad</option><option value="AIOT">AIOT</option><option value="Wearables">Wearables</option></select></div><div class="form-group"><label class="form-label">单位</label><input type="text" class="form-control" id="mat-uom"></div></div><div class="form-row"><div class="form-group"><label class="form-label">规格</label><input type="text" class="form-control" id="mat-spec"></div><div class="form-group"><label class="form-label">状态</label><select class="form-control" id="mat-status"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div></div></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('materialModal')">取消</button><button class="btn btn-primary" onclick="saveMaterial()">保存</button></div></div></div>
<div class="modal-overlay" id="storeModal"><div class="modal"><div class="modal-header"><h3 id="storeModalTitle">新增门店</h3><button class="modal-close" onclick="hideModal('storeModal')">×</button></div><div class="modal-body"><input type="hidden" id="store-edit-id"><div class="form-row"><div class="form-group"><label class="form-label">编码</label><input type="text" class="form-control" id="store-code"></div><div class="form-group"><label class="form-label">名称</label><input type="text" class="form-control" id="store-name"></div></div><div class="form-row"><div class="form-group"><label class="form-label">区域</label><input type="text" class="form-control" id="store-region"></div><div class="form-group"><label class="form-label">渠道</label><input type="text" class="form-control" id="store-channel"></div></div><div class="form-row"><div class="form-group"><label class="form-label">省份</label><input type="text" class="form-control" id="store-province"></div><div class="form-group"><label class="form-label">商场</label><input type="text" class="form-control" id="store-mall"></div></div><div class="form-row"><div class="form-group"><label class="form-label">状态</label><select class="form-control" id="store-status"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div><div class="form-group"><label class="form-label">联系人</label><input type="text" class="form-control" id="store-contact"></div></div><div class="form-row"><div class="form-group"><label class="form-label">电话</label><input type="text" class="form-control" id="store-phone"></div><div class="form-group"><label class="form-label">地址</label><input type="text" class="form-control" id="store-address"></div></div></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('storeModal')">取消</button><button class="btn btn-primary" onclick="saveStore()">保存</button></div></div></div>
<div class="modal-overlay" id="contactModal"><div class="modal"><div class="modal-header"><h3 id="contactModalTitle">新增联系人</h3><button class="modal-close" onclick="hideModal('contactModal')">×</button></div><div class="modal-body"><input type="hidden" id="contact-edit-id"><div class="form-row"><div class="form-group"><label class="form-label">姓名</label><input type="text" class="form-control" id="contact-name"></div><div class="form-group"><label class="form-label">部门</label><input type="text" class="form-control" id="contact-dept"></div></div><div class="form-row"><div class="form-group"><label class="form-label">区域-部门</label><input type="text" class="form-control" id="contact-region-dept"></div><div class="form-group"><label class="form-label">电话</label><input type="text" class="form-control" id="contact-phone"></div></div><div class="form-group"><label class="form-label">邮箱</label><input type="email" class="form-control" id="contact-email"></div></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('contactModal')">取消</button><button class="btn btn-primary" onclick="saveContact()">保存</button></div></div></div>
<div class="modal-overlay" id="receiverModal"><div class="modal"><div class="modal-header"><h3 id="receiverModalTitle">新增收货方</h3><button class="modal-close" onclick="hideModal('receiverModal')">×</button></div><div class="modal-body"><input type="hidden" id="receiver-edit-id"><div class="form-row"><div class="form-group"><label class="form-label">姓名</label><input type="text" class="form-control" id="receiver-name"></div><div class="form-group"><label class="form-label">MI ID</label><input type="text" class="form-control" id="receiver-miid"></div></div><div class="form-row"><div class="form-group"><label class="form-label">电话</label><input type="text" class="form-control" id="receiver-phone"></div><div class="form-group"><label class="form-label">区域</label><input type="text" class="form-control" id="receiver-region"></div></div><div class="form-group"><label class="form-label">部门</label><input type="text" class="form-control" id="receiver-dept"></div></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('receiverModal')">取消</button><button class="btn btn-primary" onclick="saveReceiver()">保存</button></div></div></div>
<div class="modal-overlay" id="regionModal"><div class="modal" style="max-width:400px"><div class="modal-header"><h3 id="regionModalTitle">新增区域</h3><button class="modal-close" onclick="hideModal('regionModal')">×</button></div><div class="modal-body"><input type="hidden" id="region-edit-id"><div class="form-group"><label class="form-label">名称</label><input type="text" class="form-control" id="region-name"></div><div class="form-group"><label class="form-label">状态</label><select class="form-control" id="region-status"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('regionModal')">取消</button><button class="btn btn-primary" onclick="saveRegion()">保存</button></div></div></div>
<div class="modal-overlay" id="deleteModal"><div class="modal" style="max-width:380px"><div class="modal-header"><h3>⚠️ 确认删除</h3><button class="modal-close" onclick="hideModal('deleteModal')">×</button></div><div class="modal-body"><p>确定要删除此记录吗？不可撤销。</p><input type="hidden" id="delete-table"><input type="hidden" id="delete-id"></div><div class="modal-footer"><button class="btn btn-outline" onclick="hideModal('deleteModal')">取消</button><button class="btn btn-danger" onclick="confirmDelete()">删除</button></div></div></div>

<script>
let allMaterials=[],allRegions=[],allReceivers=[];
let curPage={inbound:1,request:1};
function toast(m,t='success'){const c=document.getElementById('toastContainer'),e=document.createElement('div');e.className='toast '+t;e.innerHTML=(t==='success'?'✅':t==='error'?'❌':'ℹ️')+' '+m;c.appendChild(e);setTimeout(()=>e.remove(),3500)}
async function api(p,o={}){const h={headers:{'Content-Type':'application/json'},...o};if(h.body&&typeof h.body==='object')h.body=JSON.stringify(h.body);try{const r=await fetch('/api/'+p,h);const d=await r.json();if(!r.ok)throw new Error(d.error||'Error');return d}catch(e){toast(e.message,'error');throw e}}
function showModal(id){document.getElementById(id).classList.add('show')}
function hideModal(id){document.getElementById(id).classList.remove('show')}
function openModal(id){document.getElementById(id).classList.add('show')}
document.querySelectorAll('.tab-btn').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.tab-btn').forEach(x=>x.classList.remove('active'));document.querySelectorAll('.tab-content').forEach(x=>x.classList.remove('active'));b.classList.add('active');document.getElementById('tab-'+b.dataset.tab).classList.add('active');const t=b.dataset.tab;if(t==='inbound')loadInbound();if(t==='stock')loadStock();if(t==='request')loadRequests();if(t==='outbound')loadOutbound();if(t==='dashboard')loadDashboard();if(t==='master')loadMasterData()})});
document.querySelectorAll('.sub-tab').forEach(s=>{s.addEventListener('click',()=>{document.querySelectorAll('.sub-tab').forEach(t=>t.classList.remove('active'));document.querySelectorAll('.sub-content').forEach(c=>c.classList.remove('active'));s.classList.add('active');document.getElementById('sub-'+s.dataset.sub).classList.add('active');loadMasterData()})});
function statusBadge(s){const m={Active:'success',Completed:'success',Approved:'success',Received:'success',Planned:'info',Created:'info',Pending:'warning',Shipped:'info',Inactive:'gray',Cancelled:'danger',Rejected:'danger'};return'<span class="badge badge-'+(m[s]||'gray')+'">'+(s||'-')+'</span>'}
function onMatSearch(i,l,c,n){const v=i.value.toLowerCase(),el=document.getElementById(l);const f=allMaterials.filter(m=>m.code.toLowerCase().includes(v)||m.name.toLowerCase().includes(v)).slice(0,20);if(!v||!f.length){el.classList.remove('show');return}el.innerHTML=f.map(m=>'<div class="autocomplete-item" onclick=\'selMat("'+m.code+'","'+m.name+'","'+i.id+'","'+l+'","'+c+'","'+(n||'')+'")\'><span class="code">'+m.code+'</span><span class="name">'+m.name+'</span></div>').join('');el.classList.add('show')}
function selMat(c,ni,ii,li,ci,na){document.getElementById(ii).value=c+' - '+ni;document.getElementById(ci).value=c;if(na)document.getElementById(na).value=ni;document.getElementById(li).classList.remove('show')}
document.addEventListener('click',e=>{if(!e.target.closest('.autocomplete-wrap'))document.querySelectorAll('.autocomplete-list').forEach(l=>l.classList.remove('show'))});
async function loadDropdowns(){try{const[m,r,v]=await Promise.all([api('materials/all'),api('regions/all'),api('receivers/all')]);allMaterials=m;allRegions=r;allReceivers=v;const ro=allRegions.map(x=>'<option value="'+x+'">'+x+'</option>').join('');['ib-region','req-region'].forEach(id=>{const e=document.getElementById(id);if(e)e.innerHTML='<option value="">选择区域</option>'+ro});const s=document.getElementById('storeRegionFilter');if(s)s.innerHTML='<option value="">全部区域</option>'+ro;const de=[...new Set(allMaterials.map(x=>x.dept).filter(Boolean))];const df=document.getElementById('materialDeptFilter');if(df)df.innerHTML='<option value="">全部部门</option>'+de.map(d=>'<option value="'+d+'">'+d+'</option>').join('');const ro2=allReceivers.map(x=>'<option value="'+x.name+'">'+x.name+' ('+x.region+')</option>').join('');const re=document.getElementById('req-receiver');if(re)re.innerHTML='<option value="">选择收货人</option>'+ro2}catch(e){}}
async function loadInbound(){const s=document.getElementById('inboundSearch').value,st=document.getElementById('inboundStatusFilter').value;try{const res=await api('Inbound?page='+curPage.inbound+'&page_size=15&search='+encodeURIComponent(s)+(st?'&filter='+encodeURIComponent('CurrentValue.[Record Status]="'+st+'"'):''));const d=res.data||[];document.getElementById('inboundTable').innerHTML=d.length?d.map(r=>'<tr><td><strong>'+(r['Inbound Code']||'-')+'</strong></td><td>'+(r['Inbound Type']||'-')+'</td><td>'+(r['Material Code']||'-')+'</td><td>'+(r['Material Name']||'-')+'</td><td>'+(r['Plan Inbound Qty']||0)+'</td><td>'+(r['Actual Inbound Qty']||0)+'</td><td>'+statusBadge(r['Record Status'])+'</td><td>'+(r['Supplier']||'-')+'</td><td>'+(r['Region']||'-')+'</td><td>'+(r['Record Status']==='Planned'?'<button class="btn btn-success btn-sm" onclick="showConfirmIB(this.dataset.id,parseInt(this.dataset.q))" data-id="'+r._record_id+'" data-q="'+(r['Plan Inbound Qty']||0)+'">确认</button>':'')+'</td></tr>').join(''):'<tr><td colspan="10" class="table-empty">暂无数据</td></tr>';renderPag('inboundPagination',res,'inbound',loadInbound)}catch(e){}}
function showConfirmIB(id,qty){document.getElementById('confirm-inbound-id').value=id;document.getElementById('confirm-qty').value=qty;showModal('confirmInboundModal')}
async function confirmInbound(){const id=document.getElementById('confirm-inbound-id').value,qty=parseInt(document.getElementById('confirm-qty').value)||0;await api('inbound/confirm/'+id,{method:'POST',body:{actual_qty:qty}});hideModal('confirmInboundModal');toast('入库确认成功');loadInbound()}
async function createInbound(){const d={'Inbound Type':document.getElementById('ib-type').value,'Material Code':document.getElementById('ib-material-code').value,'Material Name':document.getElementById('ib-material-name').value,'Plan Inbound Qty':parseInt(document.getElementById('ib-qty').value)||0,'Supplier':document.getElementById('ib-supplier').value,'Region':document.getElementById('ib-region').value,'Material Department':document.getElementById('ib-dept').value,'Plan Inbound Date':document.getElementById('ib-date').value};if(!d['Material Code']){toast('请选择物料','error');return}const r=await api('inbound/create',{method:'POST',body:d});hideModal('inboundModal');toast('入库单 '+r.code+' 创建成功');loadInbound()}
async function loadStock(){try{const res=await api('Stock?page_size=200');let d=res.data||[];const s=document.getElementById('stockSearch').value.toLowerCase();if(s)d=d.filter(r=>(r['Material Code']||'').toLowerCase().includes(s)||(r['Material Name']||'').toLowerCase().includes(s));document.getElementById('stockTable').innerHTML=d.length?d.map(r=>'<tr><td><strong>'+(r['Material Code']||'-')+'</strong></td><td>'+(r['Material Name']||'-')+'</td><td>'+(r['Stock Qty']||0)+'</td><td>'+(r['Available Qty']||0)+'</td><td>'+(r['Plan Allocation Qty']||0)+'</td><td>'+(r['Wait Repair Qty']||0)+'</td><td>'+(r['Material Department']||'-')+'</td></tr>').join(''):'<tr><td colspan="7" class="table-empty">暂无数据</td></tr>';document.getElementById('stat-materials').textContent=d.length;document.getElementById('stat-stock').textContent=d.reduce((s,r)=>s+(r['Stock Qty']||0),0);document.getElementById('stat-available').textContent=d.reduce((s,r)=>s+(r['Available Qty']||0),0)}catch(e){}}
async function loadRequests(){const s=document.getElementById('requestSearch').value,st=document.getElementById('requestStatusFilter').value;try{const res=await api('Request?page='+curPage.request+'&page_size=15&search='+encodeURIComponent(s)+(st?'&filter='+encodeURIComponent('CurrentValue.[Approval Status]="'+st+'"'):''));const d=res.data||[];document.getElementById('requestTable').innerHTML=d.length?d.map(r=>'<tr><td><strong>'+(r['Request Code']||'-')+'</strong></td><td>'+(r['Material Code']||'-')+'</td><td>'+(r['Material Name']||'-')+'</td><td>'+(r['Request Qty']||0)+'</td><td>'+(r['Approved Qty']||'-')+'</td><td>'+statusBadge(r['Approval Status'])+'</td><td>'+(r['Region']||'-')+'</td><td>'+(r['Deliver type']||'-')+'</td><td>'+(r['Approval Status']==='Pending'?'<button class="btn btn-primary btn-sm" onclick="showApprove(this.dataset.id,parseInt(this.dataset.q))" data-id="'+r._record_id+'" data-q="'+(r['Request Qty']||0)+'">审批</button>':'')+'</td></tr>').join(''):'<tr><td colspan="9" class="table-empty">暂无数据</td></tr>';renderPag('requestPagination',res,'request',loadRequests)}catch(e){}}
function showApprove(id,qty){document.getElementById('approve-request-id').value=id;document.getElementById('approve-qty').value=qty;showModal('approveModal')}
async function approveRequest(){const id=document.getElementById('approve-request-id').value,qty=parseInt(document.getElementById('approve-qty').value)||0;await api('request/approve/'+id,{method:'POST',body:{approved_qty:qty}});hideModal('approveModal');toast('审批通过');loadRequests()}
async function rejectRequest(){const id=document.getElementById('approve-request-id').value;await api('request/reject/'+id,{method:'POST'});hideModal('approveModal');toast('已驳回','info');loadRequests()}
async function createRequest(){const d={'Material Code':document.getElementById('req-material-code').value,'Material Name':document.getElementById('req-material-name').value,'Request Qty':parseInt(document.getElementById('req-qty').value)||0,'Region':document.getElementById('req-region').value,'Deliver type':document.getElementById('req-deliver').value,'Receiver PIC':document.getElementById('req-receiver').value};if(!d['Material Code']){toast('请选择物料','error');return}const r=await api('request/create',{method:'POST',body:d});hideModal('requestModal');toast('申领单 '+r.code+' 创建成功');loadRequests()}
async function loadOutbound(){try{const[br,rr]=await Promise.all([api('Outbound_Batch?page_size=50'),api('Outbound_Record?page_size=50')]);const s=document.getElementById('outboundSearch').value.toLowerCase();let batches=br.data||[];if(s)batches=batches.filter(r=>(r['Batch Code']||'').toLowerCase().includes(s));document.getElementById('batchTable').innerHTML=batches.length?batches.map(r=>'<tr><td><strong>'+(r['Batch Code']||'-')+'</strong></td><td>'+statusBadge(r['Batch Status'])+'</td><td>'+(r['Included Request Count']||0)+'</td><td>'+(r['Batch Status']==='Created'?'<button class="btn btn-success btn-sm" onclick="updBatch(this.dataset.id,this.dataset.st)" data-id="'+r._record_id+'" data-st="Shipped">发货</button>':'')+'</td></tr>').join(''):'<tr><td colspan="4" class="table-empty">暂无</td></tr>';let records=rr.data||[];document.getElementById('outboundRecordTable').innerHTML=records.length?records.map(r=>'<tr><td><strong>'+(r['Outbound Code']||'-')+'</strong></td><td>'+(r['Material Code']||'-')+'</td><td>'+(r['Material Name']||'-')+'</td><td>'+statusBadge(r['Shipment Status'])+'</td><td>'+(r['Actual Outbound Qty']||0)+'</td><td>'+(r['Confirmed Receive Qty']||0)+'</td><td>'+(r['Shipment Status']==='Shipped'?'<button class="btn btn-info btn-sm" onclick="confRecv(this.dataset.id)" data-id="'+r._record_id+'">确认送达</button>':'')+'</td></tr>').join(''):'<tr><td colspan="7" class="table-empty">暂无</td></tr>'}catch(e){}}
async function createOutboundBatch(){const c=parseInt(document.getElementById('batch-req-count').value)||0;await api('outbound/create-batch',{method:'POST',body:{request_count:c}});hideModal('outboundBatchModal');toast('批次创建成功');loadOutbound()}
async function updBatch(id,st){await api('Outbound_Batch/'+id,{method:'PUT',body:{'Batch Status':st}});toast('状态已更新');loadOutbound()}
async function confRecv(id){const q=prompt('确认收货数量:');if(q===null)return;await api('outbound/confirm-receive/'+id,{method:'POST',body:{qty:parseInt(q)||0}});toast('已确认');loadOutbound()}
async function scrapStock(){const c=document.getElementById('scrap-material-code').value,q=parseInt(document.getElementById('scrap-qty').value)||0,r=document.getElementById('scrap-reason').value;if(!c){toast('请选择物料','error');return}await api('stock/scrap',{method:'POST',body:{material_code:c,scrap_qty:q,reason:r}});hideModal('scrapModal');toast('报废成功');loadStock()}
async function loadDashboard(){try{const s=await api('dashboard/stats');document.getElementById('dash-materials').textContent=s.Material_Master||0;document.getElementById('dash-stock').textContent=s.total_stock||0;document.getElementById('dash-available').textContent=s.total_available||0;document.getElementById('dash-pending').textContent=s.Request||0;document.getElementById('dash-inbound').textContent=s.Inbound||0;document.getElementById('dash-scrap').textContent=s.Scrap||0;const d=s.dept_distribution||{},mx=Math.max(...Object.values(d),1),colors=['#4f46e5','#10b981','#f59e0b','#ef4444','#3b82f6','#8b5cf6','#ec4899'];document.getElementById('deptChart').innerHTML=Object.entries(d).map(([dp,qty],i)=>'<div class="chart-bar-row"><div class="chart-bar-label">'+dp+'</div><div class="chart-bar-track"><div class="chart-bar" style="width:'+(qty/mx*100).toFixed(1)+'%;background:'+colors[i%7]+'">'+qty+'</div></div><div class="chart-bar-qty">'+qty+'</div></div>').join('')||'<p style="color:var(--gray-400);text-align:center">暂无</p>'}catch(e){}}
async function loadMasterData(){const s=document.querySelector('.sub-tab.active');if(!s)return;const sub=s.dataset.sub;if(sub==='material')await loadMaterials();if(sub==='store')await loadStores();if(sub==='contact')await loadContacts();if(sub==='receiver')await loadReceivers();if(sub==='region')await loadRegions()}
async function loadMaterials(){try{const res=await api('Material_Master?page_size=200');let d=res.data||[];const s=document.getElementById('materialSearch').value.toLowerCase(),dp=document.getElementById('materialDeptFilter').value;if(s)d=d.filter(r=>(r['Material Code']||'').toLowerCase().includes(s)||(r['Material Name']||'').toLowerCase().includes(s));if(dp)d=d.filter(r=>r['Material Department']===dp);document.getElementById('materialTable').innerHTML=d.length?d.map(r=>'<tr><td><strong>'+(r['Material Code']||'-')+'</strong></td><td>'+(r['Material Name']||'-')+'</td><td>'+(r['Material Department']||'-')+'</td><td>'+(r['UOM']||'-')+'</td><td>'+(r['Spec']||'-')+'</td><td>'+statusBadge(r['Status'])+'</td><td><button class="btn btn-outline btn-sm" onclick="editMat(_rCache[+this.dataset.i])" data-d="'+esc(JSON.stringify(r))+'">编辑</button> <button class="btn btn-danger btn-sm" onclick="showDel('Material_Master',this.dataset.id)" data-id="'+r._record_id+'">删除</button></td></tr>').join(''):'<tr><td colspan="7" class="table-empty">暂无</td></tr>'}catch(e){}}
function editMat(r){document.getElementById('materialModalTitle').textContent='编辑物料';document.getElementById('mat-edit-id').value=r._record_id;document.getElementById('mat-code').value=r['Material Code']||'';document.getElementById('mat-name').value=r['Material Name']||'';document.getElementById('mat-dept').value=r['Material Department']||'Phone';document.getElementById('mat-uom').value=r['UOM']||'';document.getElementById('mat-spec').value=r['Spec']||'';document.getElementById('mat-status').value=r['Status']||'Active';showModal('materialModal')}
async function saveMaterial(){const eid=document.getElementById('mat-edit-id').value,d={'Material Code':document.getElementById('mat-code').value,'Material Name':document.getElementById('mat-name').value,'Material Department':document.getElementById('mat-dept').value,'UOM':document.getElementById('mat-uom').value,'Spec':document.getElementById('mat-spec').value,'Status':document.getElementById('mat-status').value};if(!d['Material Code']){toast('请填写编码','error');return}if(eid){await api('Material_Master/'+eid,{method:'PUT',body:d});toast('更新成功')}else{await api('Material_Master',{method:'POST',body:d});toast('创建成功')}hideModal('materialModal');loadMaterials();loadDropdowns()}
async function loadStores(){try{const res=await api('Store_Master?page_size=200');let d=res.data||[];const s=document.getElementById('storeSearch').value.toLowerCase(),rg=document.getElementById('storeRegionFilter').value,st=document.getElementById('storeStatusFilter').value;if(s)d=d.filter(r=>(r['Shop Code']||'').toLowerCase().includes(s)||(r['Shop Name']||'').toLowerCase().includes(s));if(rg)d=d.filter(r=>r['Region']===rg);if(st)d=d.filter(r=>r['Store Status']===st);document.getElementById('storeTable').innerHTML=d.length?d.map(r=>'<tr><td><strong>'+(r['Shop Code']||'-')+'</strong></td><td>'+(r['Shop Name']||'-')+'</td><td>'+(r['Region']||'-')+'</td><td>'+(r['Channel']||'-')+'</td><td>'+(r['Province']||'-')+'</td><td>'+(r['Shopping Mall']||'-')+'</td><td>'+statusBadge(r['Store Status'])+'</td><td><button class="btn btn-outline btn-sm" onclick="editStore(_rCache[+this.dataset.i])" data-d="'+esc(JSON.stringify(r))+'">编辑</button> <button class="btn btn-danger btn-sm" onclick="showDel('Store_Master',this.dataset.id)" data-id="'+r._record_id+'">删除</button></td></tr>').join(''):'<tr><td colspan="8" class="table-empty">暂无</td></tr>'}catch(e){}}
function editStore(r){document.getElementById('storeModalTitle').textContent='编辑门店';document.getElementById('store-edit-id').value=r._record_id;document.getElementById('store-code').value=r['Shop Code']||'';document.getElementById('store-name').value=r['Shop Name']||'';document.getElementById('store-region').value=r['Region']||'';document.getElementById('store-channel').value=r['Channel']||'';document.getElementById('store-province').value=r['Province']||'';document.getElementById('store-mall').value=r['Shopping Mall']||'';document.getElementById('store-status').value=r['Store Status']||'Active';document.getElementById('store-contact').value=r['Store Contact']||'';document.getElementById('store-phone').value=r['Store Phone']||'';document.getElementById('store-address').value=r['Store Address']||'';showModal('storeModal')}
async function saveStore(){const eid=document.getElementById('store-edit-id').value,d={'Shop Code':document.getElementById('store-code').value,'Shop Name':document.getElementById('store-name').value,'Region':document.getElementById('store-region').value,'Channel':document.getElementById('store-channel').value,'Province':document.getElementById('store-province').value,'Shopping Mall':document.getElementById('store-mall').value,'Store Status':document.getElementById('store-status').value,'Store Contact':document.getElementById('store-contact').value,'Store Phone':document.getElementById('store-phone').value,'Store Address':document.getElementById('store-address').value};if(eid){await api('Store_Master/'+eid,{method:'PUT',body:d});toast('更新成功')}else{await api('Store_Master',{method:'POST',body:d});toast('创建成功')}hideModal('storeModal');loadStores()}
async function loadContacts(){try{const res=await api('Contact_Master?page_size=200');let d=res.data||[];const s=document.getElementById('contactSearch').value.toLowerCase();if(s)d=d.filter(r=>(r['Name']||'').toLowerCase().includes(s)||(r['Email']||'').toLowerCase().includes(s));document.getElementById('contactTable').innerHTML=d.length?d.map(r=>'<tr><td><strong>'+(r['Name']||'-')+'</strong></td><td>'+(r['Department']||'-')+'</td><td>'+(r['Region-Department']||'-')+'</td><td>'+(r['Phone']||'-')+'</td><td>'+(r['Email']||'-')+'</td><td><button class="btn btn-outline btn-sm" onclick="editContact(_rCache[+this.dataset.i])" data-d="'+esc(JSON.stringify(r))+'">编辑</button> <button class="btn btn-danger btn-sm" onclick="showDel('Contact_Master',this.dataset.id)" data-id="'+r._record_id+'">删除</button></td></tr>').join(''):'<tr><td colspan="6" class="table-empty">暂无</td></tr>'}catch(e){}}
function editContact(r){document.getElementById('contactModalTitle').textContent='编辑联系人';document.getElementById('contact-edit-id').value=r._record_id;document.getElementById('contact-name').value=r['Name']||'';document.getElementById('contact-dept').value=r['Department']||'';document.getElementById('contact-region-dept').value=r['Region-Department']||'';document.getElementById('contact-phone').value=r['Phone']||'';document.getElementById('contact-email').value=r['Email']||'';showModal('contactModal')}
async function saveContact(){const eid=document.getElementById('contact-edit-id').value,d={'Name':document.getElementById('contact-name').value,'Department':document.getElementById('contact-dept').value,'Region-Department':document.getElementById('contact-region-dept').value,'Phone':document.getElementById('contact-phone').value,'Email':document.getElementById('contact-email').value};if(eid){await api('Contact_Master/'+eid,{method:'PUT',body:d});toast('更新成功')}else{await api('Contact_Master',{method:'POST',body:d});toast('创建成功')}hideModal('contactModal');loadContacts()}
async function loadReceivers(){try{const res=await api('Receiver_Master?page_size=200');let d=res.data||[];const s=document.getElementById('receiverSearch').value.toLowerCase();if(s)d=d.filter(r=>(r['Name']||'').toLowerCase().includes(s)||(r['MI ID']||'').toLowerCase().includes(s));document.getElementById('receiverTable').innerHTML=d.length?d.map(r=>'<tr><td><strong>'+(r['Name']||'-')+'</strong></td><td>'+(r['MI ID']||'-')+'</td><td>'+(r['Phone']||'-')+'</td><td>'+(r['Region']||'-')+'</td><td>'+(r['Department']||'-')+'</td><td><button class="btn btn-outline btn-sm" onclick="editReceiver(_rCache[+this.dataset.i])" data-d="'+esc(JSON.stringify(r))+'">编辑</button> <button class="btn btn-danger btn-sm" onclick="showDel('Receiver_Master',this.dataset.id)" data-id="'+r._record_id+'">删除</button></td></tr>').join(''):'<tr><td colspan="6" class="table-empty">暂无</td></tr>'}catch(e){}}
function editReceiver(r){document.getElementById('receiverModalTitle').textContent='编辑收货方';document.getElementById('receiver-edit-id').value=r._record_id;document.getElementById('receiver-name').value=r['Name']||'';document.getElementById('receiver-miid').value=r['MI ID']||'';document.getElementById('receiver-phone').value=r['Phone']||'';document.getElementById('receiver-region').value=r['Region']||'';document.getElementById('receiver-dept').value=r['Department']||'';showModal('receiverModal')}
async function saveReceiver(){const eid=document.getElementById('receiver-edit-id').value,d={'Name':document.getElementById('receiver-name').value,'MI ID':document.getElementById('receiver-miid').value,'Phone':document.getElementById('receiver-phone').value,'Region':document.getElementById('receiver-region').value,'Department':document.getElementById('receiver-dept').value};if(eid){await api('Receiver_Master/'+eid,{method:'PUT',body:d});toast('更新成功')}else{await api('Receiver_Master',{method:'POST',body:d});toast('创建成功')}hideModal('receiverModal');loadReceivers()}
async function loadRegions(){try{const res=await api('Region_Config?page_size=100');const d=res.data||[];document.getElementById('regionTable').innerHTML=d.length?d.map(r=>'<tr><td><strong>'+(r['Region Name']||'-')+'</strong></td><td>'+statusBadge(r['Status'])+'</td><td><button class="btn btn-outline btn-sm" onclick="editRegion(_rCache[+this.dataset.i])" data-d="'+esc(JSON.stringify(r))+'">编辑</button> <button class="btn btn-sm '+(r['Status']==='Active'?'btn-warning':'btn-success')+'" onclick="toggleRegion(this.dataset.id,this.dataset.st)" data-id="'+r._record_id+'" data-st="'+(r['Status']==='Active'?'Inactive':'Active')+'">'+(r['Status']==='Active'?'禁用':'启用')+'</button></td></tr>').join(''):'<tr><td colspan="3" class="table-empty">暂无</td></tr>'}catch(e){}}
function editRegion(r){document.getElementById('regionModalTitle').textContent='编辑区域';document.getElementById('region-edit-id').value=r._record_id;document.getElementById('region-name').value=r['Region Name']||'';document.getElementById('region-status').value=r['Status']||'Active';showModal('regionModal')}
async function saveRegion(){const eid=document.getElementById('region-edit-id').value,d={'Region Name':document.getElementById('region-name').value,'Status':document.getElementById('region-status').value};if(eid){await api('Region_Config/'+eid,{method:'PUT',body:d});toast('更新成功')}else{await api('Region_Config',{method:'POST',body:d});toast('创建成功')}hideModal('regionModal');loadRegions()}
async function toggleRegion(id,st){await api('Region_Config/'+id,{method:'PUT',body:{'Status':st}});toast('状态已更新');loadRegions();loadDropdowns()}
function showDel(t,id){document.getElementById('delete-table').value=t;document.getElementById('delete-id').value=id;showModal('deleteModal')}
async function confirmDelete(){const t=document.getElementById('delete-table').value,id=document.getElementById('delete-id').value;await api(t+'/'+id,{method:'DELETE'});hideModal('deleteModal');toast('删除成功');loadMasterData();loadDropdowns()}
function renderPag(cid,res,tab,fn){const el=document.getElementById(cid);if(!el)return;const{page:p,total_pages:tp}=res;if(tp<=1){el.innerHTML='';return}let h='<button class="page-btn" '+(p<=1?'disabled':'')+' onclick="curPage.'+tab+'='+(p-1)+';'+fn.name+'()">‹</button>';for(let i=1;i<=tp;i++){if(i===1||i===tp||(i>=p-1&&i<=p+1)){h+='<button class="page-btn '+(i===p?'active':'')+'" onclick="curPage.'+tab+'='+i+';'+fn.name+'()">'+i+'</button>'}else if(i===p-2||i===p+2){h+='<span class="page-info">...</span>'}}h+='<button class="page-btn" '+(p>=tp?'disabled':'')+' onclick="curPage.'+tab+'='+(p+1)+';'+fn.name+'()">›</button>';el.innerHTML=h}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
async function init(){try{const c=await api('token-check');document.getElementById('connStatus').textContent=c.ok?'✅ 已连接':'❌ 失败'}catch(e){document.getElementById('connStatus').textContent='❌ 失败'}await loadDropdowns();loadInbound()}
document.querySelectorAll('.modal-overlay').forEach(m=>{m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('show')})});
init();
</script>
</body>
</html>